<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loan Approval Predictor</title>
    <link rel="stylesheet" href="style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/papaparse@5.3.2/papaparse.min.js"></script>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <header class="header">
            <h1>🏦 Loan Approval Predictor</h1>
            <p>AI-powered loan application assessment system</p>
        </header>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Input Form -->
            <div class="form-section">
                <h2>Loan Application Form</h2>
                <form id="loanForm" class="loan-form">
                    <div class="form-group">
                        <label for="education">Education:</label>
                        <select id="education" name="education" required>
                            <option value="">Select Education</option>
                            <option value="1">Graduate</option>
                            <option value="0">Not Graduate</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="self_employed">Self Employed:</label>
                        <select id="self_employed" name="self_employed" required>
                            <option value="">Select Employment</option>
                            <option value="1">Yes</option>
                            <option value="0">No</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="no_of_dependents">Number of Dependents:</label>
                        <input type="number" id="no_of_dependents" name="no_of_dependents" min="0" max="10" required>
                    </div>

                    <div class="form-group">
                        <label for="income_annum">Annual Income ($):</label>
                        <input type="number" id="income_annum" name="income_annum" min="0" step="1000" required>
                    </div>

                    <div class="form-group">
                        <label for="loan_amount">Loan Amount ($):</label>
                        <input type="number" id="loan_amount" name="loan_amount" min="0" step="1000" required>
                    </div>

                    <div class="form-group">
                        <label for="loan_term">Loan Term (months):</label>
                        <input type="number" id="loan_term" name="loan_term" min="1" max="360" required>
                    </div>

                    <div class="form-group">
                        <label for="cibil_score">CIBIL Score:</label>
                        <input type="number" id="cibil_score" name="cibil_score" min="300" max="900" required>
                    </div>

                    <div class="form-group">
                        <label for="residential_assets">Residential Assets Value ($):</label>
                        <input type="number" id="residential_assets" name="residential_assets" min="0" step="1000">
                    </div>

                    <div class="form-group">
                        <label for="commercial_assets">Commercial Assets Value ($):</label>
                        <input type="number" id="commercial_assets" name="commercial_assets" min="0" step="1000">
                    </div>

                    <div class="form-group">
                        <label for="luxury_assets">Luxury Assets Value ($):</label>
                        <input type="number" id="luxury_assets" name="luxury_assets" min="0" step="1000">
                    </div>

                    <div class="form-group">
                        <label for="bank_assets">Bank Assets Value ($):</label>
                        <input type="number" id="bank_assets" name="bank_assets" min="0" step="1000">
                    </div>

                    <button type="submit" class="submit-btn">Check Loan Eligibility</button>
                </form>
            </div>

            <!-- Results Section -->
            <div class="results-section" id="resultsSection" style="display: none;">
                <h2>Prediction Results</h2>
                <div class="result-card" id="resultCard">
                    <div class="result-header">
                        <h3 id="resultTitle">Loan Status</h3>
                        <div class="probability" id="probability">Probability: 0%</div>
                    </div>
                    <div class="result-body">
                        <div class="status-badge" id="statusBadge">
                            <span id="statusText">Pending</span>
                        </div>
                        <div class="key-factors">
                            <h4>Key Factors:</h4>
                            <ul id="factorsList"></ul>
                        </div>
                    </div>
                </div>

                <!-- Charts -->
                <div class="charts-container">
                    <div class="chart-wrapper">
                        <canvas id="featureImportanceChart"></canvas>
                    </div>
                    <div class="chart-wrapper">
                        <canvas id="riskDistributionChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Data Analysis Section -->
        <div class="analysis-section">
            <h2>📊 Model Performance & Analysis</h2>
            <div class="stats-grid">
                <div class="stat-card">
                    <h3>Model Accuracy</h3>
                    <div class="stat-value" id="accuracy">87.5%</div>
                </div>
                <div class="stat-card">
                    <h3>Precision</h3>
                    <div class="stat-value" id="precision">89.2%</div>
                </div>
                <div class="stat-card">
                    <h3>Recall</h3>
                    <div class="stat-value" id="recall">85.8%</div>
                </div>
                <div class="stat-card">
                    <h3>F1-Score</h3>
                    <div class="stat-value" id="f1score">87.4%</div>
                </div>
            </div>

            <!-- Sample Data Table -->
            <div class="data-table-section">
                <h3>Sample Loan Applications</h3>
                <div class="table-container">
                    <table id="sampleDataTable">
                        <thead>
                            <tr>
                                <th>Education</th>
                                <th>Income</th>
                                <th>Loan Amount</th>
                                <th>CIBIL</th>
                                <th>Assets</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="sampleDataBody">
                            <!-- Data will be populated by JavaScript -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>